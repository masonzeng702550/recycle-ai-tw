# ─── Vercel 自動注入（連 Storage 後不用手填）─────────────────
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
BLOB_READ_WRITE_TOKEN=

# ─── Session 簽章金鑰 ──────────────────────────────────────
# 產生：`openssl rand -base64 48`
JWT_SECRET=replace-me-with-random-48-bytes

# ─── 管理員初始帳密 ────────────────────────────────────────
# 第一次部署時用這組初始化 DB；之後從管理員頁面改密碼
# 改完密碼後 ADMIN_PASSWORD 可以從 Vercel env 移除
ADMIN_USERNAME=2T26CHOOL
ADMIN_PASSWORD=15ch00l5@M5vnG

# 進階：直接給 bcrypt hash（會優先於 ADMIN_PASSWORD）
# 產生：`npx bcryptjs <你的密碼>` 或 `node -e "console.log(require('bcryptjs').hashSync('密碼', 10))"`
ADMIN_PASSWORD_HASH=

# ─── Cloudflare Turnstile ─────────────────────────────────
# 申請：https://dash.cloudflare.com/?to=/:account/turnstile
# 下面這組是 Cloudflare 官方測試用 key（永遠通過），上線前請換掉
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
